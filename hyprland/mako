# Plik: ~/.config/mako/config

# Gdzie pojawiają się powiadomienia
anchor=top-right

# Wygląd
background-color=#141d38
text-color=#e8ecf7
border-color=#212f58
border-size=2
border-radius=10

# Rozmiar i odstępy
width=350
height=120
padding=10
margin=10

# Zachowanie
default-timeout=5000
max-visible=5
sort=-time

# Włącz ikony i formatowanie
icons=true
markup=true

# Pasek postępu (jeśli aplikacja go używa)
progress-color=over #1d2a4f

# Kolory tekstu dla grup
summary-color=#ffffff
body-color=#cfd8ef
